<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Grass field background gradient -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="#2E7D32"
                android:centerColor="#388E3C"
                android:endColor="#43A047"
                android:type="linear" />
        </shape>
    </item>
    
    <!-- Grass texture overlay (darker stripes) -->
    <item android:top="0dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:startColor="#00000000"
                android:centerColor="#1A000000"
                android:endColor="#00000000"
                android:type="linear" />
        </shape>
    </item>
    
    <!-- Football positioned on the right side -->
    <item
        android:width="30dp"
        android:height="30dp"
        android:gravity="end|center_vertical"
        android:right="8dp">
        <rotate
            android:fromDegrees="25"
            android:pivotX="50%"
            android:pivotY="50%">
            <layer-list>
                <!-- Blue Outline -->
                <item>
                    <shape android:shape="oval">
                        <solid android:color="#1976D2" />
                        <size android:width="30dp" android:height="30dp" />
                    </shape>
                </item>
                
                <!-- White Football Shape -->
                <item
                    android:top="3dp"
                    android:bottom="3dp"
                    android:left="3dp"
                    android:right="3dp">
                    <shape android:shape="oval">
                        <solid android:color="#F5F5F5" />
                    </shape>
                </item>
                
                <!-- Brown laces overlay -->
                <item
                    android:top="11dp"
                    android:bottom="11dp"
                    android:left="13dp"
                    android:right="13dp">
                    <shape android:shape="rectangle">
                        <solid android:color="#8B6F47" />
                    </shape>
                </item>
                
                <!-- Horizontal lace 1 -->
                <item
                    android:top="9dp"
                    android:bottom="19dp"
                    android:left="10dp"
                    android:right="10dp">
                    <shape android:shape="rectangle">
                        <solid android:color="#8B6F47" />
                    </shape>
                </item>
                
                <!-- Horizontal lace 2 -->
                <item
                    android:top="13dp"
                    android:bottom="15dp"
                    android:left="10dp"
                    android:right="10dp">
                    <shape android:shape="rectangle">
                        <solid android:color="#8B6F47" />
                    </shape>
                </item>
                
                <!-- Horizontal lace 3 -->
                <item
                    android:top="17dp"
                    android:bottom="11dp"
                    android:left="10dp"
                    android:right="10dp">
                    <shape android:shape="rectangle">
                        <solid android:color="#8B6F47" />
                    </shape>
                </item>
                
                <!-- Horizontal lace 4 -->
                <item
                    android:top="21dp"
                    android:bottom="7dp"
                    android:left="10dp"
                    android:right="10dp">
                    <shape android:shape="rectangle">
                        <solid android:color="#8B6F47" />
                    </shape>
                </item>
            </layer-list>
        </rotate>
    </item>
</layer-list>
