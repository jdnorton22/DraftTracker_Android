<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="8dp"
    android:layout_marginBottom="8dp">

    <!-- Position Badge -->
    <TextView
        android:id="@+id/text_position_badge"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:text="QB"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:background="@drawable/circle_position_badge" />

    <!-- Min/Max Controls -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <!-- Min Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="Min:"
                android:textSize="14sp"
                android:textColor="@color/text_primary" />

            <Button
                android:id="@+id/button_min_decrease"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="-"
                android:textSize="18sp"
                android:padding="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                style="?attr/materialButtonOutlinedStyle" />

            <TextView
                android:id="@+id/text_min_value"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:text="1"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:gravity="center"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/button_min_increase"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="+"
                android:textSize="18sp"
                android:padding="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                style="?attr/materialButtonOutlinedStyle" />

        </LinearLayout>

        <!-- Max Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="Max:"
                android:textSize="14sp"
                android:textColor="@color/text_primary" />

            <Button
                android:id="@+id/button_max_decrease"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="-"
                android:textSize="18sp"
                android:padding="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                style="?attr/materialButtonOutlinedStyle" />

            <TextView
                android:id="@+id/text_max_value"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="None"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:gravity="center"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/button_max_increase"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="+"
                android:textSize="18sp"
                android:padding="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                style="?attr/materialButtonOutlinedStyle" />

            <Button
                android:id="@+id/button_max_disable"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="None"
                android:textSize="12sp"
                android:padding="8dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:layout_marginStart="8dp"
                style="?attr/materialButtonOutlinedStyle" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
