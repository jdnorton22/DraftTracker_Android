<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="8dp"
    android:paddingEnd="8dp"
    android:paddingTop="32dp"
    android:paddingBottom="64dp"
    android:clipToPadding="false">

    <!-- Draft Info Section - Top -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="8dp"
        app:cardCornerRadius="4dp"
        app:cardElevation="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp"
            android:gravity="center">

            <TextView
                android:id="@+id/text_league_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="My Fantasy League"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:gravity="center"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/text_overall_pick"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pick 1 of 150"
                android:textSize="13sp"
                android:textStyle="italic"
                android:gravity="center"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/text_round_pick"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/round_pick_placeholder"
                android:textSize="13sp"
                android:gravity="center" />

            <TextView
                android:id="@+id/text_current_team"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/team_placeholder"
                android:textSize="13sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginTop="2dp" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Position Counts Section - Horizontal Above Best Available -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        app:cardCornerRadius="4dp"
        app:cardElevation="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Draft Summary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageButton
                        android:id="@+id/button_toggle_view"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_person_team"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:scaleType="fitCenter"
                        android:contentDescription="Toggle between Current Team and League view"
                        android:padding="4dp" />

                    <TextView
                        android:id="@+id/text_view_mode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Team"
                        android:textSize="12sp"
                        android:layout_marginStart="4dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Horizontal Position Counts -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <!-- QB Count -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/text_position_qb"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:text="QB"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:gravity="center"
                        android:background="@drawable/circle_position_badge"
                        android:layout_marginBottom="4dp" />
                    <TextView
                        android:id="@+id/text_count_qb"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:gravity="center" />
                </LinearLayout>

                <!-- RB Count -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/text_position_rb"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:text="RB"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:gravity="center"
                        android:background="@drawable/circle_position_badge"
                        android:layout_marginBottom="4dp" />
                    <TextView
                        android:id="@+id/text_count_rb"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:gravity="center" />
                </LinearLayout>

                <!-- WR Count -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/text_position_wr"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:text="WR"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:gravity="center"
                        android:background="@drawable/circle_position_badge"
                        android:layout_marginBottom="4dp" />
                    <TextView
                        android:id="@+id/text_count_wr"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:gravity="center" />
                </LinearLayout>

                <!-- TE Count -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/text_position_te"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:text="TE"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:gravity="center"
                        android:background="@drawable/circle_position_badge"
                        android:layout_marginBottom="4dp" />
                    <TextView
                        android:id="@+id/text_count_te"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:gravity="center" />
                </LinearLayout>

                <!-- K Count -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/text_position_k"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:text="K"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:gravity="center"
                        android:background="@drawable/circle_position_badge"
                        android:layout_marginBottom="4dp" />
                    <TextView
                        android:id="@+id/text_count_k"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:gravity="center" />
                </LinearLayout>

                <!-- DST Count -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/text_position_dst"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:text="DST"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:gravity="center"
                        android:background="@drawable/circle_position_badge"
                        android:layout_marginBottom="4dp" />
                    <TextView
                        android:id="@+id/text_count_dst"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:gravity="center" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Best Available Player Section -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        app:cardCornerRadius="4dp"
        app:cardElevation="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/best_available"
                android:textSize="16sp"
                android:textStyle="bold"
                android:drawableLeft="@drawable/ic_star"
                android:drawablePadding="8dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp" />

            <!-- Player Info Display (non-clickable) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:background="#F5F5F5"
                android:gravity="center"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:id="@+id/text_best_player_position_badge"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="QB"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:gravity="center"
                        android:background="@drawable/circle_position_badge"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/text_best_player_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/player_name_placeholder"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_on_light_bg"
                        android:maxLines="2"
                        android:ellipsize="end" />

                </LinearLayout>

                <TextView
                    android:id="@+id/text_best_player_position"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/position_placeholder"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:gravity="center_horizontal"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/text_best_player_injury_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:gravity="center_horizontal"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="4dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/text_best_player_stats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="11sp"
                    android:textColor="#888888"
                    android:gravity="center_horizontal"
                    android:layout_gravity="center_horizontal"
                    android:maxLines="2"
                    android:ellipsize="end" />

            </LinearLayout>

            <!-- Draft Button -->
            <Button
                android:id="@+id/button_draft_best_player"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Draft This Player"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:textAllCaps="false"
                android:minHeight="48dp"
                android:drawableLeft="@drawable/ic_check"
                android:drawablePadding="8dp" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Action Buttons Row - Make Pick and Reset Draft side by side -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp"
        android:baselineAligned="false">

        <Button
            android:id="@+id/button_make_pick"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="Draft"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:textAllCaps="false"
            android:backgroundTint="#4682B4"
            android:minHeight="56dp"
            android:drawableLeft="@drawable/ic_person"
            android:drawablePadding="8dp" />

        <Button
            android:id="@+id/button_reset_draft"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="Reset"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:textAllCaps="false"
            android:backgroundTint="#FF8C00"
            android:minHeight="56dp"
            android:drawableLeft="@drawable/ic_reset"
            android:drawablePadding="8dp" />

    </LinearLayout>

    <!-- Draft History Section - Bottom -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="4dp"
        app:cardElevation="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Recent Picks"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/button_view_history"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="View All"
                    android:textSize="14sp"
                    android:textColor="#4682B4"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground"
                    android:padding="8dp" />

            </LinearLayout>

            <!-- Recent Picks Container - 3 vertical slots -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="12dp">

                <!-- Pick Slot 1 (Most Recent) -->
                <LinearLayout
                    android:id="@+id/pick_slot_1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="8dp"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:minHeight="48dp">

                    <TextView
                        android:id="@+id/text_pick_1_number"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="--"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:gravity="center"
                        android:background="@drawable/circle_pick_number" />

                    <LinearLayout
                        android:layout_width="50dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_marginStart="4dp">

                        <TextView
                            android:id="@+id/text_pick_1_rank"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:id="@+id/text_pick_1_adp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="9sp"
                            android:textColor="@color/text_secondary"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/text_pick_1_position_rank"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="9sp"
                            android:textColor="@color/text_secondary"
                            android:visibility="gone" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="8dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:id="@+id/text_pick_1_player"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="No picks yet"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary"
                                android:maxLines="1"
                                android:ellipsize="end" />

                            <TextView
                                android:id="@+id/text_pick_1_injury_status"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=""
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:layout_marginStart="8dp"
                                android:visibility="gone" />

                        </LinearLayout>

                        <TextView
                            android:id="@+id/text_pick_1_details"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary" />

                        <TextView
                            android:id="@+id/text_pick_1_stats"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="10sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="2dp"
                            android:maxLines="1"
                            android:ellipsize="end"
                            android:visibility="gone" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?android:attr/listDivider"
                    android:layout_marginVertical="4dp" />

                <!-- Pick Slot 2 -->
                <LinearLayout
                    android:id="@+id/pick_slot_2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="8dp"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:minHeight="48dp">

                    <TextView
                        android:id="@+id/text_pick_2_number"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="--"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:gravity="center"
                        android:background="@drawable/circle_pick_number" />

                    <LinearLayout
                        android:layout_width="50dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_marginStart="4dp">

                        <TextView
                            android:id="@+id/text_pick_2_rank"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:id="@+id/text_pick_2_adp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="9sp"
                            android:textColor="@color/text_secondary"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/text_pick_2_position_rank"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="9sp"
                            android:textColor="@color/text_secondary"
                            android:visibility="gone" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="8dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:id="@+id/text_pick_2_player"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="--"
                                android:textSize="14sp"
                                android:textColor="@color/text_primary"
                                android:maxLines="1"
                                android:ellipsize="end" />

                            <TextView
                                android:id="@+id/text_pick_2_injury_status"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=""
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:layout_marginStart="8dp"
                                android:visibility="gone" />

                        </LinearLayout>

                        <TextView
                            android:id="@+id/text_pick_2_details"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary" />

                        <TextView
                            android:id="@+id/text_pick_2_stats"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="10sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="2dp"
                            android:maxLines="1"
                            android:ellipsize="end"
                            android:visibility="gone" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?android:attr/listDivider"
                    android:layout_marginVertical="4dp" />

                <!-- Pick Slot 3 (Oldest of the 3) -->
                <LinearLayout
                    android:id="@+id/pick_slot_3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="8dp"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:minHeight="48dp">

                    <TextView
                        android:id="@+id/text_pick_3_number"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="--"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:gravity="center"
                        android:background="@drawable/circle_pick_number" />

                    <LinearLayout
                        android:layout_width="50dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_marginStart="4dp">

                        <TextView
                            android:id="@+id/text_pick_3_rank"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:id="@+id/text_pick_3_adp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="9sp"
                            android:textColor="@color/text_secondary"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/text_pick_3_position_rank"
