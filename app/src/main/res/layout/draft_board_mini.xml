<?xml version="1.0" encoding="utf-8"?>
<!-- Mini draft board showing pick order visualization -->
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_small"
    app:cardCornerRadius="@dimen/card_corner_radius"
    app:cardElevation="@dimen/card_elevation">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_medium">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/spacing_small">

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Draft Board"
                android:textSize="@dimen/text_size_title"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/text_expand_board"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="View Full"
                android:textSize="@dimen/text_size_body"
                android:textColor="#4682B4"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:padding="@dimen/spacing_small"
                android:minHeight="@dimen/min_touch_target"
                android:gravity="center"
                android:contentDescription="View full draft board" />

        </LinearLayout>

        <!-- Current Round Indicator -->
        <TextView
            android:id="@+id/text_current_round_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Round 1"
            android:textSize="@dimen/text_size_small"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="@dimen/spacing_tiny" />

        <!-- Horizontal ScrollView for pick visualization -->
        <HorizontalScrollView
            android:id="@+id/scroll_draft_board"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/layout_draft_picks"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="@dimen/spacing_tiny" />

        </HorizontalScrollView>

        <!-- Upcoming Picks Section -->
        <LinearLayout
            android:id="@+id/layout_upcoming_picks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="@dimen/spacing_medium"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your Upcoming Picks"
                android:textSize="@dimen/text_size_body"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="@dimen/spacing_tiny" />

            <TextView
                android:id="@+id/text_upcoming_picks"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Picks: 12, 25, 38"
                android:textSize="@dimen/text_size_small"
                android:textColor="@color/text_secondary" />

        </LinearLayout>

        <!-- Position Needs Section -->
        <LinearLayout
            android:id="@+id/layout_position_needs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="@dimen/spacing_medium"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Position Needs"
                android:textSize="@dimen/text_size_body"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="@dimen/spacing_tiny" />

            <LinearLayout
                android:id="@+id/layout_position_needs_chips"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="@dimen/spacing_tiny" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
